# Copy to .env next to docker-compose.yml. Never commit the real .env.

# Foundry VTT account — consumed by the `foundry` service so felddy's
# entrypoint can download the licensed build on first boot.
# See https://foundryvtt.com/me/account.
FOUNDRY_USERNAME=
FOUNDRY_PASSWORD=

# Consumed by the `mcp` service for GPT-image-1 map editing. Leave blank
# to disable that tool; other MCP tools keep working.
OPENAI_API_KEY=

# Host path (or named volume) for Foundry's /data. Defaults to ./foundrydata
# next to the compose file.
FOUNDRY_DATA=./foundrydata

# Host port the character-creator SPA is served on.
WEB_PORT=8080
